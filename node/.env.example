# Single-node Node runtime. Do not set Redis, PostgreSQL, CPA, Sub2API, or Anthropic variables.
TZ=Asia/Shanghai
GROK2API_HOST=0.0.0.0
GROK2API_PORT=3000
GROK2API_DATA_DIR=/app/data-node
GROK2API_SQLITE_PATH=/app/data-node/app.sqlite

# Required before readiness and Chat/Responses traffic can be enabled.
GROK2API_XAI_UPSTREAM_BASE_URL=https://replace-with-direct-xai-endpoint/v1

GROK2API_ADMIN_PASSWORD=replace-me
GROK2API_REQUIRE_API_KEY=auto
GROK2API_DEFAULT_MODEL=grok-4.5
GROK2API_ACCOUNT_MODE=round_robin

GROK2API_TOKEN_MAINTAIN=1
GROK2API_TOKEN_MAINTAIN_INTERVAL=60
GROK2API_TOKEN_REFRESH_BATCH=20
GROK2API_TOKEN_REFRESH_WORKERS=2
GROK2API_TOKEN_REFRESH_SKEW=180
GROK2API_SSO_REAUTH_COOLDOWN=3600
GROK2API_USAGE_FLUSH_INTERVAL=15
GROK2API_USAGE_FLUSH_BATCH=100

# Cloudflare Temp Mail is the only registration mail provider.
GROK2API_CFMAIL_BASE_URL=https://replace-with-cloudflare-temp-mail-endpoint
GROK2API_CFMAIL_API_KEY=replace-me
GROK2API_CFMAIL_DOMAIN=replace-with-mail-domain
